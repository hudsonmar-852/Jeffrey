{
  "appName": "Jeffrey AI Coach OS",
  "version": "2.1",
  "defaultLocale": "zh-HK",
  "dailyUpdateTarget": "data/today.json",
  "maxMessagesPerGroup": 7,
  "weatherRole": "daily_style_driver",
  "groups": [
    "daily_special",
    "jeffrey_today",
    "weather",
    "busy_office",
    "fitness_lifestyle",
    "healthy_lifestyle",
    "recovery",
    "senior_safe",
    "long_time_no_see"
  ],
  "quality": {
    "minHumanScore": 88,
    "maxAiSmellPercent": 20,
    "onePurposeOnly": true,
    "avoidRepeatedOpenings": true,
    "newRemindersSortedToTop": true,
    "preserveOldReminders": true
  }
}
